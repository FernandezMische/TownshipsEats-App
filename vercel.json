{
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "text/css" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)\\.css",
      "dest": "/assets/$1.css"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
